generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoryType {
  video
  article
}

model Story {
  id          String    @id @default(uuid())
  type        StoryType
  title       String
  category    String
  thumbnail   String
  featured    Boolean   @default(false)
  duration    String?
  location    String?
  description String?
  youtubeId   String?
  readTime    String?
  author      String?
  date        String?
  excerpt     String?
  body        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([category])
  @@index([featured])
}

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  emailSent Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DiasporaSubmission {
  id         String   @id @default(uuid())
  name       String
  email      String
  phone      String
  country    String
  profession String?
  interest   String
  message    String
  emailSent  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}